# Comma-separated notification destinations: discord, telegram, or discord,telegram.
NOTIFIERS=discord

# Discord notifier. Required when NOTIFIERS includes discord.
DISCORD_WEBHOOK_URL=<your-discord-webhook-url>

# Telegram notifier. Required when NOTIFIERS includes telegram.
# Create a bot with @BotFather, add it to a chat/channel, and set the chat id here.
TELEGRAM_BOT_TOKEN=<your-telegram-bot-token>
TELEGRAM_CHAT_ID=<your-telegram-chat-id>
TELEGRAM_DISABLE_WEB_PAGE_PREVIEW=false

# TradingView watchlist.
WATCHLIST_NAME=TradingView Watchlist
WATCHLIST_URL=https://www.tradingview.com/watchlists/<watchlist-id>/

# State snapshot location. Relative paths are resolved from the project root.
STATE_FILE=state/watchlist_<watchlist-id>.json

# US regular session defaults. The scheduler treats weekdays as trading days;
# holidays are not excluded unless you pause the daemon yourself.
MARKET_TIMEZONE=America/New_York
MARKET_OPEN=09:30
MARKET_CLOSE=16:00
CHECK_INTERVAL_MARKET_SECONDS=900
CHECK_INTERVAL_OFFHOURS_SECONDS=21600
SNAPSHOT_HOURS=0,6,12,18
SNAPSHOT_WINDOW_MINUTES=45

# Browser options.
HEADLESS=true
# Optional: use a Playwright storage_state JSON file if TradingView requires login/cookies.
# TV_STORAGE_STATE=state/tradingview_storage_state.json

# Safety/testing.
DRY_RUN=false
SEND_INITIAL_BASELINE=false

# GitHub Actions should set this to false so no-change scans do not create state commits.
PERSIST_LAST_SEEN=true
